# Copy this file to .env and fill in the values.
# .env is gitignored; .env.example is committed as documentation.

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# SEC EDGAR requires a User-Agent header identifying the requester.
# Format: "Your Name your@email.com"
# Requests without a valid User-Agent are rejected by data.sec.gov.
SEC_USER_AGENT=